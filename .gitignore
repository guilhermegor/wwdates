# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Virtual environments
.venv/
venv/
env/

# uv
.uv/

# Distribution / packaging
# dist/ holds build artifacts and `make ship` zips — ignore its contents but keep
# the tracked dist/.keep so the directory ships with the scaffold.
build/
dist/*
!dist/.keep
*.egg-info/

# IDE / editor
# Ship the curated VS Code settings + tasks; ignore everything else under .vscode/.
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
.idea/
*.swp

# Test / coverage
# coverage.svg is tracked (the README badge references it); coverage.xml is the
# transient genbadge input and is regenerated on every run.
.coverage
coverage.xml
htmlcov/

# MkDocs build output (generated by `mkdocs build`)
site/

# pre-commit check-urls hook cache
.url_check_cache/

# Git-diff offline-sync exports (present only when scaffolded without GitHub)
/git_diffs/

# Repo→LLM context dump generated by `make export_context`
/repo_context.txt

# Corporate CA (generated locally by `make get_corporate_ca` — never committed)
bin/corporate_ca.pem

# Scaffoldable lessons — local working copy only; the canonical, cross-project
# store lives globally in ~/.claude/memory/lessons/. Never committed here.
docs/blueprintx-lessons.md

# Environment files — ignore real env files, keep .env.example tracked
.env
.env.local
.env.dev
.env.development
.env.test
.env.staging
.env.prod
.env.production

# Local dev SQLite artifact (config.connection_db default DB_PATH=./data/app.db when
# DB_BACKEND=sqlite). The runtime DB is never committed; .env.example documents DB_PATH.
data/app.db
